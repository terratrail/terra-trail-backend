# ==============================================================================
# TerraTrail SaaS Backend - Environment Variables Template
# ==============================================================================
# NOTE: DO NOT commit your actual .env file. Use this as a reference.

# ------------------------------------------------------------------------------
# 1. CORE DJANGO SETTINGS
# ------------------------------------------------------------------------------
# The module containing your settings (use production for live)
DJANGO_SETTINGS_MODULE=terratrail.settings.production

# Must be 'False' in production!
DEBUG=False

# A long, random string. Must be kept completely secret.
# In production, use `python -c "import secrets; print(secrets.token_urlsafe(50))"`
SECRET_KEY=your-very-long-and-secure-random-string

# Comma-separated list of domains allowed to host your API
# E.g., api.terratrail.com,app.terratrail.com
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7


# ------------------------------------------------------------------------------
# 2. DATABASE & REDIS
# ------------------------------------------------------------------------------
# Provided by your hosting platform (Render/Heroku/AWS RDS)
# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgres://terratrail_user:terratrail_password@db:5432/terratrail

REDIS_URL=redis://localhost:6379/0
# Redis connection string for Celery background tasks
# Format: redis://HOST:PORT/DB_INDEX
CELERY_BROKER_URL=redis://redis:6379/0


# ------------------------------------------------------------------------------
# 3. AWS S3 (STATIC / MEDIA ASSETS)
# ------------------------------------------------------------------------------
# Required for storing property images, receipts, and documents
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=your_s3_bucket_name
AWS_S3_REGION_NAME=us-east-1


# ------------------------------------------------------------------------------
# 4. EMAIL & SMS PROVIDERS (To be configured)
# ------------------------------------------------------------------------------
# E.g., SendGrid, Mailgun, or standard SMTP
EMAIL_HOST=smtp.sendgrid.net
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your_sendgrid_api_key
DEFAULT_FROM_EMAIL=noreply@terratrail.io

# SMS (abstracted)
SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER_ID=TerraTrail

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=15

# Session
CUSTOMER_SESSION_TIMEOUT_MINUTES=30

# Company / SaaS Identity
COMPANY_NAME=TerraTrail Technologies Ltd
SUPPORT_EMAIL=support@terratrail.io
SALES_EMAIL=sales@terratrail.io
BILLING_EMAIL=billing@terratrail.io

# URLs
FRONTEND_BASE_URL=https://app.terratrail.io
BACKEND_BASE_URL=https://api.terratrail.io

# Payment / Bank Details
BANK_NAME=Guaranty Trust Bank
BANK_ACCOUNT_NAME=TerraTrail Technologies Ltd
BANK_ACCOUNT_NUMBER=your-account-number-here
PAYMENT_CURRENCY=NGN

# E.g., Termii, Twilio API Keys
SMS_PROVIDER_API_KEY=your_sms_provider_key
